#!/bin/sh
set -e

TOP=$(dirname "$0")

if [ $# -eq 0 ]; then
  echo "Usage:"
  echo "$0 <docker container name>"
  exit 1
fi

# コンテナ名をHEX(67682d636f6465)に変換
HEX=$(printf '%s' "${1}" | xxd -p | tr -d '\n')
# 既存コンテナがない場合のみ起動。初回アタッチ失敗を避けるため、先に起動完了まで待つ。
code --folder-uri "vscode-remote://attached-container+${HEX}/workdir/"


